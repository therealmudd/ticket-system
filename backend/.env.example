# Use "production" for the real event environment.
# Non-production values also enable the /email-preview test page.
APP_ENV=local

# Non-production APP_ENV values automatically prefix Firestore collections,
# for example local_tickets and local_daily_counters.
# Set this only if you want to override that automatic prefix.
# FIRESTORE_COLLECTION_PREFIX=local_

# Use "console" locally to generate tickets and PDFs without sending email.
# Use "smtp" when you want Gmail SMTP to send the message.
EMAIL_MODE=console

# Optional: send every email to one test inbox while preserving X-Original-To.
# EMAIL_REDIRECT_TO=your-test-address@example.com

TICKET_IMAGE=ticket2.png
MAX_TICKETS_PER_REQUEST=10

# Use "2" for denser QR codes. Use "1" to generate old plain-reference QRs.
QR_PAYLOAD_VERSION=2
QR_PAYLOAD_PADDING=LT_ANNUAL_BALL_ENTRY_VALIDATION_PAYLOAD

# Required for Firebase.
FIREBASE_CREDENTIALS_B64=

# Required only when EMAIL_MODE=smtp.
EMAIL=
EMAIL_PASSWORD=


